# GPU/CPU 调度配置
# 自动生成 - 2026-04-10

# CUDA GPU 设备
CUDA_VISIBLE_DEVICES=0

# Ollama GPU 配置
OLLAMA_GPU_LAYERS=33
OLLAMA_NUM_PARALLEL=4
OLLAMA_NUM_THREAD=8

# 显存管理
MAX_GPU_MEMORY=28GB
GPU_OVERALLOCATION_FACTOR=1.1

# 缓存配置
CACHE_DIR=./cache
TEMP_DIR=./temp

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 监控配置
MONITOR_INTERVAL=60
ALERT_THRESHOLD_CPU=90
ALERT_THRESHOLD_MEMORY=95
