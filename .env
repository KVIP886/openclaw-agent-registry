# GPU/CPU 调度配置
# 自动生成 - 2026-04-10

# CUDA GPU 设备
CUDA_VISIBLE_DEVICES=0

# Ollama GPU 配置
OLLAMA_GPU_LAYERS=33
OLLAMA_NUM_PARALLEL=4
OLLAMA_NUM_THREADS=8

# 显存管理
MAX_GPU_MEMORY=28GB
GPU_OVERALLOCATION_FACTOR=1.1

# 缓存配置
CACHE_DIR=./cache
TEMP_DIR=./temp

# 日志配置
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# 监控配置
MONITOR_INTERVAL=60
ALERT_THRESHOLD_CPU=90
ALERT_THRESHOLD_MEMORY=95

# === OpenClaw 2026.4.9 New Features ===
# Memory/Dreaming System (Optional, default: disabled)
MEMORY_DREAM_ENABLED=true
MEMORY_DREAM_RETENTION_DAYS=30
MEMORY_DREAM_MAX_AGE_DAYS=90
MEMORY_DREAM_RECALL_HALF_LIFE_DAYS=7

# Video Generation Settings (Optional, defaults apply)
VIDEO_GENERATION_MAX_DURATION=15
VIDEO_GENERATION_DEFAULT_RESOLUTION=1080p
VIDEO_GENERATION_FALLBACK_ENABLED=true
VIDEO_GENERATION_MAX_FALLBACK_ATTEMPTS=3

# Audio Generation Settings (Optional, default: disabled)
AUDIO_GENERATION_ENABLED=false

# Security Settings (2026.4.9, default: enabled)
SECURITY_SSRF_ENABLED=true
SECURITY_PLUGIN_SIGNING_ENABLED=true
SECURITY_ENV_VAR_SANITIZATION=true
SECURITY_ALLOWLIST_HOSTNAME_PROXY=true

# Chinese UI Localization (Optional, default: English)
UI_LANGUAGE=en
UI_LOCALIZATION_ENABLED=true

# AReaL Integration (Optional, default: disabled)
AREAL_ENABLED=false
AREAL_MODE=medium
AREAL_BATCH_SIZE=512

# Logging Enhancements (2026.4.9)
LOG_AUDIT_ENABLED=true

# 2026 Video Prompt Standards
VIDEO_PROMPT_STANDARD=2026
VIDEO_PROMPT_24FPS=true
VIDEO_PROMPT_VOLUMETRIC_LIGHTING=true
VIDEO_PROMPT_MOTION_BLUR=true
VIDEO_PROMPT_REALISTIC_PHYSICS=true
VIDEO_PROMPT_LARGE_FORMAT_PHOTOREAL=true
